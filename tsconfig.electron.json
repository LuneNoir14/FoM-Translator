{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.electron.tsbuildinfo",
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist-electron",
    "rootDir": ".",
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": false,
    "noEmit": false
  },
  "include": ["electron/**/*.cts", "src/main/**/*.ts", "src/shared/**/*.ts"]
}
